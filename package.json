{
  "name": "@lnpg/sol",
  "version": "1.0.1",
  "description": "Framework agnostic design foundation for UI kits and applications.",
  "homepage": "https://github.com/lnpgdev/sol#readme",
  "bugs": {
    "url": "https://github.com/lnpgdev/sol/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lnpgdev/sol.git"
  },
  "license": "ISC",
  "author": "LNPG Development Team",
  "type": "module",
  "style": "./dist/css/main.css",
  "files": [
    "dist",
    "src/scss",
    "src/ts",
    "src/elements"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "types": "./dist/types/index.d.ts",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "pre:build": "npm exec --no -- unicode-scrub --fix \"./**/*\"",
    "lint": "npm run lint:scss && npm run lint:ts",
    "lint:fix": "npm run lint:scss:fix && npm run lint:ts:fix",
    "lint:ts": "eslint 'src/**/*.{ts,tsx}' --max-warnings=0",
    "lint:ts:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --config stylelint.config.cjs",
    "lint:scss:fix": "stylelint \"src/**/*.scss\" --fix --config stylelint.config.cjs",
    "prettier": "npm run prettier:scss && npm run prettier:ts",
    "prettier:fix": "npm run prettier:scss:fix && npm run prettier:ts:fix && npm run prettier:misc:fix",
    "prettier:ts": "prettier \"src/**/*.{ts,tsx}\"",
    "prettier:ts:fix": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prettier:scss": "prettier \"**/*.{scss,css,md,json,yml,yaml}\"",
    "prettier:scss:fix": "prettier --ignore-path .prettierignore --no-error-on-unmatched-pattern --write \"src/**/*.{scss,css}\"",
    "prettier:misc": "prettier \"**/*.{md,json,yml,yaml}\"",
    "prettier:misc:fix": "prettier --write \"**/*.{md,json,yml,yaml}\"",
    "tsc": "tsc -p tsconfig.types.json --noEmit",
    "build:types": "tsc -p tsconfig.types.json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .tsbuildinfo.types",
    "check": "npm run lint:fix && npm run prettier:fix && npm run tsc",
    "test": "vitest run",
    "build": "npm run pre:build && npm run clean && npm run check && npm run test && npm run build:all",
    "build:all": "npm run build:css && npm run build:js && npm run build:types",
    "docs": "npm run docs:copy:assets && npm run docs:scss && npm run docs:ts && npm run docs:build",
    "docs:scss": "echo \"Placeholder (tbc)\"",
    "docs:ts": "typedoc --options typedoc.config.cjs",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview public",
    "docs:copy:assets": "rimraf docs/public/assets/fonts && mkdir -p docs/public/assets/fonts && cp -R src/assets/fonts/* docs/public/assets/fonts",
    "build:css": "npm run build:css:main && npm run build:css:core && npm run build:css:elements",
    "build:js": "vite build --mode esm && vite build --mode cjs",
    "build:css:core": "sass --style=compressed src/scss/core.scss dist/css/core.css",
    "build:css:main": "sass --style=compressed src/scss/main.scss dist/css/main.css",
    "build:css:elements": "sass --style=compressed src/elements:dist/css/elements",
    "copy:assets": "npm run copy:assets:fonts",
    "copy:assets:fonts": "rimraf dist/assets/fonts && mkdir -p dist/assets/fonts && cp -R src/assets/fonts/* dist/assets/fonts",
    "prepublishOnly": "npm run pre:build && npm run clean && npm run check && npm run test:coverage && npm run build:all && npm run copy:assets && npm run docs"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "sass": "^1.97.2",
    "sass-embedded": "^1.97.2",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "stylelint": "^17.2.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "stylelint-order": "^7.0.1",
    "vitest": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "vitepress": "^1.6.4",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.10.0",
    "@lnpg/unicode-scrub": "^1.0.0",
    "rimraf": "^6.1.2",
    "postcss-scss": "^4.0.9",
    "globals": "^17.3.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
