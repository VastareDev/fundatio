{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "rootDir": "src",
    "stripInternal": true,
    "isolatedDeclarations": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo.types"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
